generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  unlockedAchievements Json @default("[]")
  // Founder Edition purchase flag — a standing account-level grant of every
  // content id, current and future, rather than a per-content Purchase row.
  founderAllFuture Boolean @default(false)
  accounts      Account[]
  sessions      Session[]
  games         Game[]
  purchases     Purchase[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Game {
  id              String     @id @default(cuid())
  userId          String
  presidentName   String
  party           Party
  difficulty      String     @default("normal")
  // Plain string, not an enum, so a new Premium Campaign era ships as a
  // pure data-file change (see lib/content-sources.ts) with no migration —
  // same precedent as difficulty above. Set once at creation, never
  // re-derived or changed after (see lib/db-helpers.ts's dbToGame).
  campaignEra     String     @default("modern")
  currentMonth    Int        @default(1)
  status          GameStatus @default(ACTIVE)
  stats           Json
  flags           Json       @default("{}")
  activeConflicts Json       @default("[]")
  activeScandals  Int        @default(0)
  pendingConsequences Json   @default("[]")
  chainCooldowns  Json       @default("{}")
  npcRelationships Json      @default("{}")
  usedNpcAbilities Json      @default("[]")
  passedLaws      Json       @default("[]")
  usedEvents      Json       @default("[]")
  approvalHistory Json       @default("[]")
  cabinetSelections Json     @default("{}")
  npcTraits       Json       @default("{}")
  npcObservations Json       @default("{}")
  priorities      Json       @default("[]")
  legacyScore     Int?
  currentEventId  String?
  createdAt       DateTime   @default(now()) @db.Timestamp(3)
  // Capped at millisecond precision because turn/law routes use this column
  // for optimistic locking (WHERE updatedAt: <value read via Prisma>) — Postgres's
  // default timestamp precision is microseconds, but JS Date (and therefore
  // Prisma's read-back value) only holds milliseconds, so an update's WHERE
  // clause would never match its own previous write and every turn past the
  // first would fail with a false "already processed" conflict.
  updatedAt       DateTime   @updatedAt @db.Timestamp(3)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs            GameLog[]

  @@index([userId, updatedAt])
  @@index([status, legacyScore])
}

model GameLog {
  id          String     @id @default(cuid())
  gameId      String
  month       Int
  actionType  ActionType
  eventId     String?
  choiceIndex Int?
  lawId       String?
  statDeltas  Json
  narrative   String?
  createdAt   DateTime   @default(now())
  game        Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId, month])
}

// One-time content purchase (Stripe Checkout, mode: payment — no
// subscriptions). Insert-only ledger, not a state machine: COMPLETED rows
// are created by the Stripe webhook on checkout.session.completed;
// REFUNDED is set manually via support tooling (not built yet) and is
// the only other state a row can reach.
model Purchase {
  id                     String         @id @default(cuid())
  userId                 String
  // Key into lib/content-catalog.ts's PRODUCT_CATALOG (what was bought).
  productId              String
  // string[] snapshot of the content ids this product granted AT PURCHASE
  // TIME — see lib/content-catalog.ts for why this isn't re-derived from
  // productId at read time.
  contentIds             Json
  // lib/content-catalog.ts's CONTENT_CATALOG_VERSION at purchase time —
  // support/audit trail only, never read for entitlement gating.
  catalogVersion         Int
  // Unique so the webhook's upsert is idempotent against Stripe's
  // documented at-least-once event redelivery.
  stripeSessionId        String         @unique
  stripePaymentIntentId  String?
  amountCents            Int
  currency               String         @default("usd")
  status                 PurchaseStatus @default(COMPLETED)
  createdAt              DateTime       @default(now())
  user                   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum PurchaseStatus {
  COMPLETED
  REFUNDED
}

enum Party {
  DEMOCRAT
  REPUBLICAN
  INDEPENDENT
}

enum GameStatus {
  ACTIVE
  COMPLETE
  GAMEOVER
}

enum ActionType {
  CRISIS
  LAW_PROPOSED
  LAW_PASSED
  LAW_FAILED
  BUDGET
  EXECUTIVE_ORDER
  PRESS_CONFERENCE
  DIPLOMATIC_VISIT
  TURN_END
  PERSONNEL
}
